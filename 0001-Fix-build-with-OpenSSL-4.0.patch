From c0ba8a40a8ce26e89f2f8b0391fdf3e9087a0c25 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Bernhard=20Rosenkr=C3=A4nzer?= <bero@lindev.ch>
Date: Mon, 15 Jun 2026 13:55:29 +0200
Subject: [PATCH 1/2] Fix build with OpenSSL 4.0

X509_CRL_get_issuer, X509_get_issuer_name, X509_get_subject_name,
X509_NAME_get_entry, X509_NAME_ENTRY_get_data and
X509_EXTENSION_get_data now return const pointers.

Use const_cast at the call sites (compatible with older OpenSSL and
BoringSSL) and update a few local variables to const.

Replace direct accesses to ASN1_OCTET_STRING members for IP SANs with
the accessor functions ASN1_STRING_length and ASN1_STRING_get0_data.

Update one test that used the removed TLSv1_2_server_method symbol.
---
 .../transport/tls/grpc_tls_crl_provider.cc    |  2 +-
 src/core/tsi/ssl_transport_security.cc        | 20 +++++++++----------
 src/core/tsi/ssl_transport_security_utils.cc  | 10 +++++-----
 test/core/handshake/client_ssl.cc             |  2 +-
 4 files changed, 17 insertions(+), 17 deletions(-)

diff --git a/src/core/credentials/transport/tls/grpc_tls_crl_provider.cc b/src/core/credentials/transport/tls/grpc_tls_crl_provider.cc
index 7bd4c5ab..1f7a5015 100644
--- a/src/core/credentials/transport/tls/grpc_tls_crl_provider.cc
+++ b/src/core/credentials/transport/tls/grpc_tls_crl_provider.cc
@@ -56,7 +56,7 @@ absl::StatusOr<std::string> IssuerFromCrl(X509_CRL* crl) {
   if (crl == nullptr) {
     return absl::InvalidArgumentError("crl cannot be null");
   }
-  X509_NAME* issuer = X509_CRL_get_issuer(crl);
+  X509_NAME* issuer = const_cast<X509_NAME*>(X509_CRL_get_issuer(crl));
   if (issuer == nullptr) {
     return absl::InvalidArgumentError("crl cannot have null issuer");
   }
